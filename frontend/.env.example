# Base URL of the CareerNexus backend API — must include the /api/v1 prefix
# the backend uses for every route. Leave unset to run in demo/mock mode.
VITE_API_URL=http://localhost:5000/api/v1

# Socket.io server URL for real-time notifications, messages, and status updates.
VITE_SOCKET_URL=http://localhost:5000
